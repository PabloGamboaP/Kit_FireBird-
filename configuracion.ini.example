[FIREBIRD]
# Configuracion de conexion a la base de datos Firebird

# IP o nombre del servidor Firebird (dejar vacio para modo embedded/local)
host = 

# Ruta completa al archivo de base de datos
# Para modo local: usar ruta local (C:\temp\activos.gdb)
# Para modo remoto: usar ruta en el servidor (D:/DATOS TNS/ACTIVOS_UNP_COPIA.GDB)
database = C:\temp\activos.gdb

# Usuario de base de datos
user = SYSDBA

# Contraseña (solicitar al administrador de BD)
password = TU_PASSWORD_AQUI

# Charset (NO CAMBIAR - la base usa WIN1252)
charset = WIN1252

# Puerto (default: 3050)
port = 3050

# Año y mes para consultas (fecha de la copia de la base)
ano_consulta = 2026
mes_consulta = 02
